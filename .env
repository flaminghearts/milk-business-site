# MooFresh Payment Gateway Configurations

# Base application URL (used for payment redirection and callbacks)
BASE_URL=http://127.0.0.1:8000

# Safaricom M-Pesa Daraja API Settings
# Register/Get keys from: https://developer.safaricom.co.ke/
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=placeholder_mpesa_consumer_key
MPESA_CONSUMER_SECRET=placeholder_mpesa_consumer_secret
# Default Daraja sandbox Shortcode is 174379, and Passkey is standard
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Stripe API Settings (for Credit/Debit Card Checkout redirect)
# Register/Get keys from: https://dashboard.stripe.com/
STRIPE_PUBLISHABLE_KEY=placeholder_stripe_publishable_key
STRIPE_SECRET_KEY=placeholder_stripe_secret_key

# SMTP Configuration (for delivery email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=placeholder_email@gmail.com
SMTP_PASSWORD=placeholder_email_password

